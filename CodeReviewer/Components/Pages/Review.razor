</style>

@code {
    string codeContent = "";
    string selectedPersona = "Standard";
    bool isLoading = false;
    string? errorMessage;
    ReviewResponseDto? responseDto;

    string activeTab = "Bugs";

    // Chat
    bool isChatting = false;
    bool isStreaming = false;
    string chatInput = "";
    List<ChatMessage> chatHistory = new();
    ElementReference chatContainerRef;

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }

    bool isCopied = false;
    bool isTestsCopied = false;

    // Translation
    string targetLanguage = "Python";
    string translatedToLanguage = "";   // language of the current result (set on success)
    bool isTranslating = false;
    TranslateResponseDto? translationResult = null;
    bool isTranslationCopied = false;

    private static string GetPrismClass(string lang) => lang.ToLower() switch
    {
        "csharp"      => "language-csharp",
        "typescript"  => "language-typescript",
        "javascript"  => "language-javascript",
        "java"        => "language-java",
        "go"          => "language-go",
        "rust"        => "language-rust",
        "kotlin"      => "language-kotlin",
        _             => "language-python"
    };

    // Diff
    record DiffLine(string Type, string Content);

    static List<DiffLine> ComputeDiff(string original, string fixedCode)
    {
        var origLines = (original ?? "").Split('\n');
        var fixedLines = (fixedCode ?? "").Split('\n');
        int m = origLines.Length, n = fixedLines.Length;

        var dp = new int[m + 1, n + 1];
        for (int i = 1; i <= m; i++)
            for (int j = 1; j <= n; j++)
                dp[i, j] = origLines[i - 1] == fixedLines[j - 1]
                    ? dp[i - 1, j - 1] + 1
                    : Math.Max(dp[i - 1, j], dp[i, j - 1]);

        var diff = new List<DiffLine>();
        int x = m, y = n;
        while (x > 0 || y > 0)
        {
            if (x > 0 && y > 0 && origLines[x - 1] == fixedLines[y - 1])
            { diff.Add(new DiffLine("equal", origLines[x - 1])); x--; y--; }
            else if (y > 0 && (x == 0 || dp[x, y - 1] >= dp[x - 1, y]))
            { diff.Add(new DiffLine("insert", fixedLines[y - 1])); y--; }
            else
            { diff.Add(new DiffLine("delete", origLines[x - 1])); x--; }
        }
        diff.Reverse();
        return diff;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (responseDto != null)
        {
            if (activeTab is "FixedCode" or "Tests")
                try { await JS.InvokeVoidAsync("highlightCode"); } catch { }
            else if (activeTab == "Flowchart")
                try { await JS.InvokeVoidAsync("renderMermaid"); } catch { }
        }
        if (translationResult?.TranslatedCode != null)
            try { await JS.InvokeVoidAsync("highlightCode"); } catch { }
    }

    async Task CopyFixedCode()
    {
        if (responseDto != null && !string.IsNullOrEmpty(responseDto.FixedCode))
        {
            await JS.InvokeVoidAsync("clipboardCopy.copyText", responseDto.FixedCode);
            isCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            isCopied = false;
            StateHasChanged();
        }
    }

    async Task DoTranslate()
    {
        if (string.IsNullOrWhiteSpace(codeContent))
        {
            translationResult = new TranslateResponseDto { ErrorMessage = "Vui lòng nhập code trước khi dịch." };
            return;
        }

        isTranslating = true;
        translationResult = null;
        translatedToLanguage = targetLanguage;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var request = new TranslateRequestDto { Code = codeContent, TargetLanguage = targetLanguage };
            var response = await http.PostAsJsonAsync("api/review/translate", request);

            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<TranslateResponseDto>();
                if (dto != null && !string.IsNullOrEmpty(dto.ErrorMessage))
                    translationResult = dto;
                else
                    translationResult = dto;
            }
            else
            {
                translationResult = new TranslateResponseDto { ErrorMessage = $"API lỗi: {(int)response.StatusCode} {response.StatusCode}" };
            }
        }
        catch (Exception ex)
        {
            translationResult = new TranslateResponseDto { ErrorMessage = $"Không thể kết nối API: {ex.Message}" };
        }
        finally
        {
            isTranslating = false;
        }
    }

    async Task CopyTranslation()
    {
        if (translationResult != null && !string.IsNullOrEmpty(translationResult.TranslatedCode))
        {
            await JS.InvokeVoidAsync("clipboardCopy.copyText", translationResult.TranslatedCode);
            isTranslationCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            isTranslationCopied = false;
            StateHasChanged();
        }
    }

    async Task CopyUnitTests()
    {
        if (responseDto != null && !string.IsNullOrEmpty(responseDto.UnitTests))
        {
            await JS.InvokeVoidAsync("clipboardCopy.copyText", responseDto.UnitTests);
            isTestsCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            isTestsCopied = false;
            StateHasChanged();
        }
    }

    async Task SendToReview()
    {
        if (string.IsNullOrWhiteSpace(codeContent))
        {
            errorMessage = "Vui lòng nhập code trước khi review.";
            return;
        }

        isLoading = true;
        responseDto = null;
        errorMessage = null;
        chatHistory.Clear();
        activeTab = "Bugs";

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var request = new ReviewRequestDto { Code = codeContent, Persona = selectedPersona };
            var response = await http.PostAsJsonAsync("api/review", request);

            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<ReviewResponseDto>();
                if (dto != null && !string.IsNullOrEmpty(dto.ErrorMessage))
                {
                    errorMessage = dto.ErrorMessage;
                }
                else
                {
                    responseDto = dto;
                }
            }
            else
            {
                errorMessage = $"API trả về lỗi: {(int)response.StatusCode} {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể kết nối API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task HandleChatKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isChatting && !string.IsNullOrWhiteSpace(chatInput))
        {
            await SendChat();
        }
    }

    async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(chatInput) || isChatting) return;

        var userText = chatInput.Trim();
        chatInput = "";

        chatHistory.Add(new ChatMessage { Text = userText, IsUser = true });

        var aiMessage = new ChatMessage { Text = "", IsUser = false };
        chatHistory.Add(aiMessage);

        isChatting = true;
        isStreaming = false;
        await InvokeAsync(StateHasChanged);

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var historyStr = string.Join("\n",
                chatHistory.SkipLast(1).Select(m => (m.IsUser ? "User: " : "AI: ") + m.Text));

            var requestDto = new ChatRequestDto
            {
                OriginalCode = codeContent ?? "",
                ChatHistory = historyStr,
                UserMessage = userText
            };

            bool streamSucceeded = false;
            try
            {
                var req = new HttpRequestMessage(HttpMethod.Post, "api/review/chat/stream");
                req.Content = JsonContent.Create(requestDto);
                using var response = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);

                if (response.IsSuccessStatusCode)
                {
                    isStreaming = true;
                    using var stream = await response.Content.ReadAsStreamAsync();
                    using var reader = new StreamReader(stream);

                    while (!reader.EndOfStream)
                    {
                        var line = await reader.ReadLineAsync();
                        if (line?.StartsWith("data: ") != true) continue;
                        var data = line.Substring(6);
                        if (data == "[DONE]") break;
                        try
                        {
                            var chunk = System.Text.Json.JsonSerializer.Deserialize<string>(data);
                            if (chunk != null)
                            {
                                aiMessage.Text += chunk;
                                streamSucceeded = true;
                                await InvokeAsync(StateHasChanged);
                                try { await JS.InvokeVoidAsync("scrollToBottom", chatContainerRef); } catch { }
                            }
                        }
                        catch { }
                    }
                }
            }
            catch { }

            if (!streamSucceeded)
            {
                // Fallback to regular (blocking) endpoint
                isStreaming = false;
                await InvokeAsync(StateHasChanged);
                var response = await http.PostAsJsonAsync("api/review/chat", requestDto);
                if (response.IsSuccessStatusCode)
                {
                    var chatResponse = await response.Content.ReadFromJsonAsync<ChatResponseDto>();
                    aiMessage.Text = chatResponse?.Reply ?? "⚠️ Không có phản hồi";
                }
                else
                {
                    aiMessage.Text = "⚠️ Lỗi kết nối API";
                }
            }
        }
        catch (Exception ex)
        {
            aiMessage.Text = $"⚠️ Đã xảy ra lỗi: {ex.Message}";
        }
        finally
        {
            isChatting = false;
            isStreaming = false;
            await InvokeAsync(StateHasChanged);
            try { await JS.InvokeVoidAsync("scrollToBottom", chatContainerRef); } catch { }
        }
    }
}