    // Share feature
    async Task ShareReview()
    {
        if (responseDto == null) return;
        isSharing = true;
        StateHasChanged();
        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var payload = new { ReviewData = responseDto, OriginalCode = codeContent ?? "" };
            var resp = await http.PostAsJsonAsync("api/share", payload);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<ShareResult>();
                if (result != null)
                {
                    var baseUrl = Nav.BaseUri.TrimEnd('/');
                    shareUrl = $"{baseUrl}/share/{result.Id}";
                    showShareModal = true;
                }
            }
        }
        catch { }
        finally { isSharing = false; }
    }

    async Task CopyShareUrl()
    {
        await JS.InvokeVoidAsync("clipboardCopy.copyText", shareUrl);
        isShareUrlCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        isShareUrlCopied = false;
        StateHasChanged();
    }

    record ShareResult(string Id, DateTime CreatedAt);

    // Per-bug fix suggestions
    Dictionary<int, string> bugFixes = new();
    HashSet<int> loadingBugFixes = new();

    async Task GetBugFix(int idx, BugDto bug)
    {
        if (loadingBugFixes.Contains(idx)) return;
        loadingBugFixes.Add(idx);
        bugFixes.Remove(idx);
        StateHasChanged();

        try
        {
            // Extract a small context window around the bug line from the reviewed code
            var codeContext = "";
            if (!string.IsNullOrEmpty(reviewedCode) && bug.Line > 0)
            {
                var lines = reviewedCode.Split('\n');
                var from = Math.Max(0, bug.Line - 6);
                var to   = Math.Min(lines.Length - 1, bug.Line + 6);
                codeContext = string.Join('\n', lines[from..(to + 1)]);
            }
            else if (!string.IsNullOrEmpty(reviewedCode))
            {
                codeContext = reviewedCode.Length > 2000 ? reviewedCode[..2000] : reviewedCode;
            }

            var prompt = string.IsNullOrEmpty(codeContext)
                ? $"Lỗi: {bug.Description}\n\nHãy giải thích ngắn gọn cách sửa lỗi này bằng tiếng Việt và cung cấp đoạn code mẫu đã sửa."
                : $"Lỗi phát hiện: {bug.Description}\n\nĐoạn code liên quan (quanh line {bug.Line}):\n```\n{codeContext}\n```\n\nHãy chỉ ra cách sửa lỗi này bằng tiếng Việt. Chỉ hiển thị đoạn code đã sửa (ngắn gọn), không giải thích dài dòng.";

            var http = HttpClientFactory.CreateClient("ReviewApi");
            var req = new HttpRequestMessage(HttpMethod.Post, "api/review/chat/stream");
            req.Content = System.Net.Http.Json.JsonContent.Create(new ChatRequestDto
            {
                OriginalCode = codeContext,
                ChatHistory  = "",
                UserMessage  = prompt
            });

            var fixBuilder = new System.Text.StringBuilder();
            using var response = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);
            if (response.IsSuccessStatusCode)
            {
                using var stream = await response.Content.ReadAsStreamAsync();
                using var reader = new System.IO.StreamReader(stream);
                while (!reader.EndOfStream)
                {
                    var line = await reader.ReadLineAsync();
                    if (line?.StartsWith("data: ") != true) continue;
                    var data = line[6..];
                    if (data == "[DONE]") break;
                    try
                    {
                        var chunk = System.Text.Json.JsonSerializer.Deserialize<string>(data);
                        if (chunk != null) { fixBuilder.Append(chunk); bugFixes[idx] = fixBuilder.ToString(); await InvokeAsync(StateHasChanged); }
                    }
                    catch { }
                }
            }

            if (fixBuilder.Length == 0) bugFixes[idx] = "Không thể tạo gợi ý sửa lỗi lúc này.";
        }
        catch { bugFixes[idx] = "Không thể tạo gợi ý sửa lỗi lúc này."; }
        finally { loadingBugFixes.Remove(idx); StateHasChanged(); }
    }

    // History
    async Task OpenHistory()
    {
        showHistory = true;
        await LoadHistory();
    }

    async Task LoadHistory()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "reviewHistory");
            if (!string.IsNullOrEmpty(json))
            {
                var list = System.Text.Json.JsonSerializer.Deserialize<List<HistoryItem>>(json);
                reviewHistory = list ?? new();
            }
        }
        catch { }
    }

    async Task SaveToHistory(ReviewResponseDto data, string code)
    {
        try
        {
            await LoadHistory();
            var snippet = code.Split('\n').FirstOrDefault()?.Trim() ?? "";
            if (snippet.Length > 60) snippet = snippet[..60] + "...";
            var item = new HistoryItem(snippet, data.PerformanceScore, data.SecurityScore,
                data.MaintainabilityScore, data.DetectedBugs?.Count ?? 0, data, code, DateTime.Now);
            reviewHistory.Insert(0, item);
            if (reviewHistory.Count > 20) reviewHistory = reviewHistory.Take(20).ToList();
            var json = System.Text.Json.JsonSerializer.Serialize(reviewHistory);
            await JS.InvokeVoidAsync("localStorage.setItem", "reviewHistory", json);
        }
        catch { }
    }

    async Task RestoreHistory(HistoryItem item)
    {
        codeContent = item.OriginalCode;
        responseDto = item.ReviewData;
        inputMode = "code";
        showHistory = false;
        activeTab = "Bugs";
        await InvokeAsync(StateHasChanged);
    }

    async Task ClearHistory()
    {
        reviewHistory.Clear();
        await JS.InvokeVoidAsync("localStorage.removeItem", "reviewHistory");
    }

    async Task HandleChatKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isChatting && !string.IsNullOrWhiteSpace(chatInput))
        {
            await SendChat();
        }
    }

    async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(chatInput) || isChatting) return;

        var userText = chatInput.Trim();
        chatInput = "";

        chatHistory.Add(new ChatMessage { Text = userText, IsUser = true });

        var aiMessage = new ChatMessage { Text = "", IsUser = false };
        chatHistory.Add(aiMessage);

        isChatting = true;
        isStreaming = false;
        _chatCts = new CancellationTokenSource();
        var ct = _chatCts.Token;
        await InvokeAsync(StateHasChanged);

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var historyStr = string.Join("\n",
                chatHistory.SkipLast(1).Select(m => (m.IsUser ? "User: " : "AI: ") + m.Text));

            // Build review context so AI knows what was just analyzed
            var reviewCtx = "";
            if (responseDto != null)
            {
                var sb = new System.Text.StringBuilder();
                sb.AppendLine($"Điểm số: Hiệu suất {responseDto.PerformanceScore}/100 | Bảo mật {responseDto.SecurityScore}/100 | Bảo trì {responseDto.MaintainabilityScore}/100");
                if (!string.IsNullOrEmpty(responseDto.Summary))
                    sb.AppendLine($"Tổng quan: {responseDto.Summary}");
                if (responseDto.DetectedBugs?.Count > 0)
                {
                    sb.AppendLine($"Phát hiện {responseDto.DetectedBugs.Count} lỗi:");
                    foreach (var b in responseDto.DetectedBugs)
                        sb.AppendLine($"  - Line {b.Line}: {b.Description}");
                }
                else
                {
                    sb.AppendLine("Không phát hiện lỗi nào.");
                }
                reviewCtx = sb.ToString();
            }

            var requestDto = new ChatRequestDto
            {
                OriginalCode = reviewedCode.Length > 0 ? (reviewedCode.Length > 8000 ? reviewedCode[..8000] + "\n[... truncated ...]" : reviewedCode) : (codeContent ?? ""),
                ChatHistory = historyStr,
                UserMessage = userText,
                ReviewContext = reviewCtx
            };

            bool streamSucceeded = false;
            try
            {
                var req = new HttpRequestMessage(HttpMethod.Post, "api/review/chat/stream");
                req.Content = JsonContent.Create(requestDto);
                using var response = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead, ct);

                if (response.IsSuccessStatusCode)
                {
                    isStreaming = true;
                    using var stream = await response.Content.ReadAsStreamAsync(ct);
                    using var reader = new StreamReader(stream);

                    while (!reader.EndOfStream && !ct.IsCancellationRequested)
                    {
                        var line = await reader.ReadLineAsync(ct);
                        if (line?.StartsWith("data: ") != true) continue;
                        var data = line.Substring(6);
                        if (data == "[DONE]") break;
                        try
                        {
                            var chunk = System.Text.Json.JsonSerializer.Deserialize<string>(data);
                            if (chunk != null)
                            {
                                aiMessage.Text += chunk;
                                streamSucceeded = true;
                                await InvokeAsync(StateHasChanged);
                                try { await JS.InvokeVoidAsync("scrollToBottom", chatContainerRef); } catch { }
                            }
                        }
                        catch { }
                    }

                    if (ct.IsCancellationRequested && streamSucceeded)
                        streamSucceeded = true; // keep partial text, don't fallback
                }
            }
            catch (OperationCanceledException) { streamSucceeded = aiMessage.Text.Length > 0; }
            catch { }

            if (!streamSucceeded && !ct.IsCancellationRequested)
            {
                // Fallback to regular (blocking) endpoint
                isStreaming = false;
                await InvokeAsync(StateHasChanged);
                var response = await http.PostAsJsonAsync("api/review/chat", requestDto, ct);
                if (response.IsSuccessStatusCode)
                {
                    var chatResponse = await response.Content.ReadFromJsonAsync<ChatResponseDto>(cancellationToken: ct);
                    aiMessage.Text = chatResponse?.Reply ?? "⚠️ Không có phản hồi";
                }
                else
                {
                    aiMessage.Text = "⚠️ Lỗi kết nối API";
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            aiMessage.Text = $"⚠️ Đã xảy ra lỗi: {ex.Message}";
        }
        finally
        {
            _chatCts?.Dispose();
            _chatCts = null;
            isChatting = false;
            isStreaming = false;
            await InvokeAsync(StateHasChanged);
            try { await JS.InvokeVoidAsync("scrollToBottom", chatContainerRef); } catch { }
            try { await JS.InvokeVoidAsync("focusElement", chatInputRef); } catch { }
        }
    }
