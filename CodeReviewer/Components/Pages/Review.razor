@page "/"
@page "/review"

@using AIReviewerAPI.DTOs
@using System.Net.Http.Json

@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<div class="reviewer-wrapper">
    <div class="reviewer-container">

        <div class="text-center mb-5 mt-3">
            <div class="badge-premium mb-3">✨ AI-Powered Code Assistant</div>
            <h2 class="hero-title">Paste your code & get instant AI review</h2>
            <p class="text-muted fs-5">Powered by Gemini AI — Find bugs, improve quality, and chat with your code.</p>
        </div>

        <div class="row g-4">
            <!-- CODE INPUT -->
            <div class="col-lg-6 d-flex flex-column">
                <div class="panel flex-grow-1">
                    <div class="panel-header">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-code-slash text-info"></i>
                            <span>Code Input</span>
                        </div>
                        <span class="badge bg-secondary opacity-75 rounded-pill">@(codeContent?.Length ?? 0) chars</span>
                    </div>
                    <div class="p-3 pb-0 bg-white border-bottom">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <label class="fw-bold text-muted" style="font-size: 0.9rem;">
                                <i class="bi bi-person-badge-fill text-primary"></i> Persona:
                            </label>
                            <select class="form-select form-select-sm shadow-sm w-auto" @bind="selectedPersona" style="border-radius: 8px; font-weight: 500;">
                                <option value="Standard">👨‍💻 Cố vấn tiêu chuẩn</option>
                                <option value="GordonRamsay">👨‍🍳 Gordon Ramsay (Khắt khe)</option>
                                <option value="AnimeWaifu">🌸 Anime Waifu (Đáng yêu)</option>
                            </select>
                        </div>
                    </div>
                    <textarea class="code-editor"
                              @bind="codeContent"
                              placeholder="// Paste your C# code here...
// AI will analyze and fix it for you!"></textarea>
                </div>

                <button class="btn-review mt-4 flex-shrink-0"
                        @onclick="SendToReview"
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Đang phân tích hệ thống...</span>
                    }
                    else
                    {
                        <span><i class="bi bi-rocket-takeoff me-2"></i> Review Code</span>
                    }
                </button>

                <div class="translate-bar mt-3 d-flex gap-2 flex-shrink-0">
                    <select class="form-select shadow-sm" @bind="targetLanguage" style="border-radius: 10px; font-weight: 500; font-size: 0.95rem;">
                        <option value="Python">🐍 Python</option>
                        <option value="TypeScript">📘 TypeScript</option>
                        <option value="JavaScript">💛 JavaScript</option>
                        <option value="CSharp">💜 C#</option>
                        <option value="Java">☕ Java</option>
                        <option value="Go">🔵 Go</option>
                        <option value="Rust">🦀 Rust</option>
                        <option value="Kotlin">🟣 Kotlin</option>
                    </select>
                    <button class="btn-translate flex-shrink-0" @onclick="DoTranslate" disabled="@isTranslating">
                        @if (isTranslating)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-translate me-1"></i>
                        }
                        Dịch
                    </button>
                </div>
            </div>

            <!-- RESULT -->
            <div class="col-lg-6 d-flex flex-column">
                <div class="panel flex-grow-1 d-flex flex-column">
                    <div class="panel-header">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-clipboard2-check text-success"></i>
                            <span>Review Result</span>
                        </div>
                        @if (responseDto != null)
                        {
                            <span class="badge bg-danger rounded-pill pulse-animation">
                                @(responseDto.DetectedBugs?.Count ?? 0) issues
                            </span>
                        }
                    </div>
                    
                    @if (responseDto != null)
                    {
                        <div class="tab-header">
                            <button class="tab-btn @(activeTab == "Bugs" ? "active" : "")" 
                                    @onclick="@(() => activeTab = "Bugs")">
                                <i class="bi bi-bug me-1"></i> Phân tích
                            </button>
                            <button class="tab-btn @(activeTab == "Flowchart" ? "active" : "")" 
                                    @onclick="@(() => activeTab = "Flowchart")">
                                <i class="bi bi-diagram-3 me-1"></i> Sơ đồ thuật toán
                            </button>
                            <button class="tab-btn @(activeTab == "FixedCode" ? "active" : "")"
                                    @onclick="@(() => activeTab = "FixedCode")">
                                <i class="bi bi-magic me-1"></i> Auto Fix
                            </button>
                            <button class="tab-btn @(activeTab == "Diff" ? "active" : "")"
                                    @onclick="@(() => activeTab = "Diff")">
                                <i class="bi bi-file-diff me-1"></i> Diff
                            </button>
                            <button class="tab-btn @(activeTab == "Tests" ? "active" : "")"
                                    @onclick="@(() => activeTab = "Tests")">
                                <i class="bi bi-clipboard2-pulse me-1"></i> Unit Tests
                            </button>
                        </div>
                    }

                    <div class="result-content flex-grow-1 custom-scrollbar">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center gap-3 glass-alert">
                                <span class="fs-3">⚠️</span> 
                                <div><strong>Lỗi hệ thống!</strong><br/>@errorMessage</div>
                            </div>
                        }
                        else if (responseDto != null)
                        {
                            @if (activeTab == "Bugs")
                            {
                                <div class="scores-container d-flex flex-wrap gap-4 mb-4 mt-1">
                                    <div class="score-item flex-grow-1">
                                        <div class="d-flex justify-content-between text-muted mb-1" style="font-size: 0.85rem;">
                                            <span class="fw-bold"><i class="bi bi-lightning-charge-fill text-warning"></i> Hiệu suất</span>
                                            <span class="fw-bold text-dark">@responseDto.PerformanceScore/100</span>
                                        </div>
                                        <div class="progress" style="height: 10px; border-radius: 10px; background: #f1f5f9;">
                                            <div class="progress-bar bg-warning" role="progressbar" style="width: @(responseDto.PerformanceScore)%; transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                                        </div>
                                    </div>
                                    <div class="score-item flex-grow-1">
                                        <div class="d-flex justify-content-between text-muted mb-1" style="font-size: 0.85rem;">
                                            <span class="fw-bold"><i class="bi bi-shield-lock-fill text-danger"></i> Bảo mật</span>
                                            <span class="fw-bold text-dark">@responseDto.SecurityScore/100</span>
                                        </div>
                                        <div class="progress" style="height: 10px; border-radius: 10px; background: #f1f5f9;">
                                            <div class="progress-bar bg-danger" role="progressbar" style="width: @(responseDto.SecurityScore)%; transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1); background-image: linear-gradient(45deg,rgba(255,255,255,.15) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.15) 50%,rgba(255,255,255,.15) 75%,transparent 75%,transparent);"></div>
                                        </div>
                                    </div>
                                    <div class="score-item flex-grow-1">
                                        <div class="d-flex justify-content-between text-muted mb-1" style="font-size: 0.85rem;">
                                            <span class="fw-bold"><i class="bi bi-code-square text-success"></i> Khả năng bảo trì</span>
                                            <span class="fw-bold text-dark">@responseDto.MaintainabilityScore/100</span>
                                        </div>
                                        <div class="progress" style="height: 10px; border-radius: 10px; background: #f1f5f9;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width: @(responseDto.MaintainabilityScore)%; transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="summary-box position-relative">
                                    <strong><i class="bi bi-card-text me-1"></i> Tổng quan (Summary)</strong>
                                    <p>@responseDto.Summary</p>
                                </div>

                                @if (responseDto.DetectedBugs != null && responseDto.DetectedBugs.Any())
                                {
                                    @if (!string.IsNullOrEmpty(responseDto.HackerExploit))
                                    {
                                        <div class="hacker-alert mb-4">
                                            <div class="hacker-header">
                                                <i class="bi bi-incognito"></i> <span>Hacker Exploit Simulator</span>
                                            </div>
                                            <div class="hacker-body">
                                                <p class="mb-2 text-danger fw-bold">⚠️ Cảnh báo lỗ hổng bảo mật nghiêm trọng!</p>
                                                <p class="mb-2">Một hacker có thể tấn công hệ thống của bạn bằng đoạn mã sau:</p>
                                                <pre class="hacker-code"><code>@responseDto.HackerExploit</code></pre>
                                            </div>
                                        </div>
                                    }

                                    <div class="mt-3 mb-2 fw-bold text-muted ps-1">Danh sách lỗi phát hiện:</div>
                                    @foreach (var bug in responseDto.DetectedBugs)
                                    {
                                        <div class="bug-item">
                                            <div class="d-flex align-items-start gap-3">
                                                <div class="bug-line">Line @bug.Line</div>
                                                <div class="bug-desc flex-grow-1">@bug.Description</div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-success d-flex align-items-center gap-3 glass-alert-success mt-4">
                                        <span class="fs-1">🎉</span> 
                                        <div>
                                            <strong>Tuyệt vời!</strong><br/>
                                            Code của bạn trông rất chuẩn chỉ. Không phát hiện lỗi nào!
                                        </div>
                                    </div>
                                }
                            }
                            else if (activeTab == "Flowchart")
                            {
                                <div class="alert alert-info glass-alert-info mb-3 d-flex align-items-center">
                                    <i class="bi bi-info-circle-fill me-2"></i> 
                                    <span>AI đã phân tích và vẽ ra sơ đồ luồng thuật toán (Flowchart) cho đoạn code của bạn.</span>
                                </div>
                                @if (!string.IsNullOrEmpty(responseDto.MermaidChart))
                                {
                                    <div class="flowchart-container custom-scrollbar d-flex justify-content-center align-items-start p-4 bg-white rounded border">
                                        <div class="mermaid">
                                            @{
                                                var rawChart = responseDto.MermaidChart ?? "";
                                                if (rawChart.Contains("```mermaid"))
                                                {
                                                    rawChart = rawChart.Replace("```mermaid", "").Replace("```", "").Trim();
                                                }
                                            }
                                            @rawChart
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted mt-5">
                                        <i class="bi bi-diagram-2 fs-1"></i>
                                        <p class="mt-2">Không thể tạo sơ đồ cho đoạn code này.</p>
                                    </div>
                                }
                            }
                            else if (activeTab == "FixedCode")
                            {
                                <div class="d-flex justify-content-between align-items-center alert alert-info glass-alert-info mb-3">
                                    <div>
                                        <i class="bi bi-info-circle-fill me-2"></i>
                                        Đoạn code đã được AI làm sạch và tối ưu.
                                    </div>
                                    <button class="btn btn-sm btn-primary fw-bold px-3 shadow-sm" @onclick="CopyFixedCode" style="border-radius: 8px; transition: all 0.3s;">
                                        <i class="bi @(isCopied ? "bi-check2-all" : "bi-clipboard") me-1"></i> @(isCopied ? "Đã Copy!" : "Copy")
                                    </button>
                                </div>
                                <div class="code-preview-container custom-scrollbar">
                                    <pre class="m-0"><code class="language-csharp">@responseDto.FixedCode</code></pre>
                                </div>
                            }
                            else if (activeTab == "Diff")
                            {
                                <div class="alert alert-secondary glass-alert-info mb-3 d-flex align-items-center">
                                    <i class="bi bi-file-diff me-2"></i>
                                    <span>So sánh code gốc (trái) và code đã sửa (phải). <span class="badge bg-danger">— Xóa</span> <span class="badge bg-success ms-1">+ Thêm</span></span>
                                </div>
                                @if (string.IsNullOrEmpty(responseDto.FixedCode))
                                {
                                    <div class="text-center text-muted mt-5">
                                        <i class="bi bi-file-diff fs-1"></i>
                                        <p class="mt-2">Không có code đã sửa để so sánh.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="diff-container custom-scrollbar">
                                        @foreach (var line in ComputeDiff(codeContent, responseDto.FixedCode ?? ""))
                                        {
                                            <div class="diff-line diff-@line.Type">
                                                <span class="diff-prefix">@(line.Type == "insert" ? "+" : line.Type == "delete" ? "-" : " ")</span>
                                                <span class="diff-content">@line.Content</span>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else if (activeTab == "Tests")
                            {
                                <div class="d-flex justify-content-between align-items-center alert alert-info glass-alert-info mb-3">
                                    <div>
                                        <i class="bi bi-clipboard2-pulse me-2"></i>
                                        Unit Tests được AI tự động tạo ra bằng xUnit.
                                    </div>
                                    <button class="btn btn-sm btn-primary fw-bold px-3 shadow-sm" @onclick="CopyUnitTests" style="border-radius: 8px; transition: all 0.3s;">
                                        <i class="bi @(isTestsCopied ? "bi-check2-all" : "bi-clipboard") me-1"></i> @(isTestsCopied ? "Đã Copy!" : "Copy")
                                    </button>
                                </div>
                                @if (string.IsNullOrEmpty(responseDto.UnitTests))
                                {
                                    <div class="text-center text-muted mt-5">
                                        <i class="bi bi-clipboard2-x fs-1"></i>
                                        <p class="mt-2">Không thể tạo unit tests cho đoạn code này.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="code-preview-container custom-scrollbar">
                                        <pre class="m-0"><code class="language-csharp">@responseDto.UnitTests</code></pre>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <div class="empty-icon-wrapper pulse-animation-slow">
                                    <span class="empty-icon">✨</span>
                                </div>
                                <h4>Chưa có dữ liệu</h4>
                                <p>Hãy dán code vào khung bên trái và bấm <strong>Review Code</strong> để bắt đầu!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- TRANSLATION RESULT -->
        @if (translationResult != null)
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="panel translation-panel">
                        <div class="panel-header">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-translate text-warning"></i>
                                <span>
                                    Bản dịch:
                                    @if (!string.IsNullOrEmpty(translationResult.SourceLanguage))
                                    {
                                        <span class="badge bg-secondary ms-1 me-1">@translationResult.SourceLanguage</span>
                                        <i class="bi bi-arrow-right me-1"></i>
                                    }
                                    <span class="badge bg-warning text-dark ms-1">@translatedToLanguage</span>
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(translationResult.TranslatedCode))
                            {
                                <button class="btn btn-sm btn-outline-light fw-bold px-3" @onclick="CopyTranslation" style="border-radius: 8px;">
                                    <i class="bi @(isTranslationCopied ? "bi-check2-all" : "bi-clipboard") me-1"></i> @(isTranslationCopied ? "Đã Copy!" : "Copy")
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(translationResult.ErrorMessage))
                        {
                            <div class="alert alert-danger m-3 d-flex align-items-center gap-2">
                                <span class="fs-4">⚠️</span>
                                <div><strong>Lỗi!</strong> @translationResult.ErrorMessage</div>
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(translationResult.Notes))
                            {
                                <div class="translation-notes">
                                    <i class="bi bi-lightbulb-fill text-warning me-2"></i>
                                    <strong>Ghi chú dịch thuật:</strong> @translationResult.Notes
                                </div>
                            }
                            <div class="code-preview-container custom-scrollbar translation-code">
                                <pre class="m-0"><code class="@GetPrismClass(translatedToLanguage)">@translationResult.TranslatedCode</code></pre>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- CHAT WITH CODE SECTION -->
        @if (responseDto != null)
        {
            <div class="row mt-5 mb-5 pb-5">
                <div class="col-12">
                    <div class="panel chat-panel">
                        <div class="panel-header bg-gradient-dark">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-chat-dots-fill text-primary"></i>
                                <span>Trợ lý AI (Chat với Code)</span>
                            </div>
                            <span class="badge bg-primary rounded-pill">Trực tuyến</span>
                        </div>
                        <div class="chat-container p-4 custom-scrollbar" @ref="chatContainerRef">
                            @if (chatHistory.Count == 0)
                            {
                                <div class="d-flex justify-content-center align-items-center h-100">
                                    <div class="text-center text-muted chat-placeholder">
                                        <i class="bi bi-robot fs-1 mb-2 text-primary opacity-50"></i>
                                        <h5>AI đã sẵn sàng!</h5>
                                        <p>Hãy hỏi tôi bất kỳ điều gì về đoạn code trên.<br/>(VD: "Tại sao lỗi dòng 5?", "Sửa hàm này dùng LINQ")</p>
                                    </div>
                                </div>
                            }
                            
                            @foreach(var msg in chatHistory)
                            {
                                <div class="d-flex mb-4 @(msg.IsUser ? "justify-content-end" : "justify-content-start")">
                                    @if (!msg.IsUser) { <div class="chat-avatar bg-gradient-dark me-2"><i class="bi bi-robot"></i></div> }
                                    
                                    <div style="max-width: 75%;">
                                        <div class="chat-bubble @(msg.IsUser ? "chat-bubble-user" : "chat-bubble-ai")">
                                            @msg.Text
                                        </div>
                                    </div>

                                    @if (msg.IsUser) { <div class="chat-avatar bg-primary ms-2"><i class="bi bi-person-fill"></i></div> }
                                </div>
                            }
                            @if(isChatting && !isStreaming)
                            {
                                <div class="d-flex mb-4 justify-content-start">
                                    <div class="chat-avatar bg-gradient-dark me-2"><i class="bi bi-robot"></i></div>
                                    <div class="chat-bubble chat-bubble-ai d-flex align-items-center gap-2">
                                        <div class="typing-dot"></div>
                                        <div class="typing-dot" style="animation-delay: 0.2s"></div>
                                        <div class="typing-dot" style="animation-delay: 0.4s"></div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="p-3 bg-white d-flex gap-3 align-items-center chat-input-area border-top">
                            <input type="text" class="form-control chat-input" 
                                   @bind="chatInput" @bind:event="oninput" @onkeyup="HandleChatKeyUp" 
                                   placeholder="Nhập câu hỏi của bạn..." />
                            <button class="btn-send" @onclick="SendChat" disabled="@(isChatting || string.IsNullOrWhiteSpace(chatInput))">
                                <i class="bi bi-send-fill"></i> Gửi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap');
    @@import url('https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css');

    body {
        background-color: #f1f5f9;
        font-family: 'Outfit', sans-serif;
    }

    .reviewer-wrapper {
        min-height: 100vh;
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05), transparent 400px),
                    radial-gradient(circle at bottom left, rgba(236, 72, 153, 0.05), transparent 400px);
    }

    .reviewer-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }

    /* ===== HERO ===== */
    .badge-premium {
        display: inline-block;
        padding: 0.4rem 1rem;
        background: rgba(99, 102, 241, 0.1);
        color: #4f46e5;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(99, 102, 241, 0.2);
    }

    .hero-title {
        font-weight: 800;
        font-size: 2.8rem;
        background: linear-gradient(135deg, #4f46e5, #9333ea, #db2777);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradientShift 6s ease infinite;
        background-size: 200% 200%;
        margin-bottom: 0.5rem;
    }

    @@keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    /* ===== PANELS ===== */
    .panel {
        background: #ffffff;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 16px;
        box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }
    .panel:hover {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.12);
    }

    .panel-header {
        background: #0f172a;
        color: #f8fafc;
        padding: 1rem 1.5rem;
        font-weight: 600;
        font-size: 1rem;
        border-bottom: 1px solid #1e293b;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .bg-gradient-dark {
        background: linear-gradient(to right, #0f172a, #1e293b);
    }

    /* ===== CODE EDITOR ===== */
    .code-editor {
        width: 100%;
        height: 480px;
        border: none;
        outline: none;
        padding: 1.5rem;
        font-family: 'Fira Code', Consolas, monospace;
        font-size: 14.5px;
        line-height: 1.7;
        background: #0f172a;
        color: #e2e8f0;
        resize: none;
    }
    .code-editor::placeholder {
        color: #475569;
        font-style: italic;
    }
    .code-editor:focus {
        background: #111827;
    }
    
    .code-preview-container {
        height: 380px;
        background: #2d2d2d;
        border-radius: 8px;
        overflow: auto;
        padding: 1.5rem;
    }
    
    .code-preview-container pre {
        background: transparent !important;
        padding: 0 !important;
        margin: 0 !important;
        text-shadow: none !important;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    /* Custom Scrollbar */
    .custom-scrollbar::-webkit-scrollbar,
    .code-editor::-webkit-scrollbar {
        width: 8px;
