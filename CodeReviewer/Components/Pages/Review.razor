        isTranslating = true;
        translationResult = null;
        translatedToLanguage = targetLanguage;
        StateHasChanged();

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var request = new TranslateRequestDto { Code = codeContent, TargetLanguage = targetLanguage };
            var response = await http.PostAsJsonAsync("api/review/translate", request);

            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<TranslateResponseDto>();
                if (dto != null && !string.IsNullOrEmpty(dto.ErrorMessage))
                    translationResult = dto;
                else
                    translationResult = dto;
            }
            else
            {
                translationResult = new TranslateResponseDto { ErrorMessage = $"API lỗi: {(int)response.StatusCode} {response.StatusCode}" };
            }
        }
        catch (Exception ex)
        {
            translationResult = new TranslateResponseDto { ErrorMessage = $"Không thể kết nối API: {ex.Message}" };
