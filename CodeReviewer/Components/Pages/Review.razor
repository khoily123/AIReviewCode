            { errorMessage = "Vui lòng nhập URL GitHub PR."; return; }
            if (!System.Text.RegularExpressions.Regex.IsMatch(githubPrUrl.Trim(),
                @"github\.com/[^/]+/[^/?#]+", System.Text.RegularExpressions.RegexOptions.IgnoreCase))
            { errorMessage = "URL không đúng định dạng. Ví dụ: https://github.com/owner/repo"; return; }
        }

        isLoading = true;
        responseDto = null;
        errorMessage = null;
        chatHistory.Clear();
        activeTab = "Bugs";
        reviewedCode = "";
        reviewedInputMode = inputMode;

        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            ReviewResponseDto? dto = null;

            if (inputMode == "github")
            {
                var payload = new { PrUrl = githubPrUrl.Trim(), GithubToken = githubToken.Trim(), Persona = selectedPersona };
                var response = await http.PostAsJsonAsync("api/github/pr-review", payload);
                if (response.IsSuccessStatusCode)
                {
                    dto = await response.Content.ReadFromJsonAsync<ReviewResponseDto>();
                    reviewedCode = $"// GitHub PR: {githubPrUrl.Trim()}";
                }
                else
                {
                    var body = await response.Content.ReadAsStringAsync();
                    try
                    {
                        var err = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(body);
                        errorMessage = err?.GetValueOrDefault("message") ?? $"GitHub PR lỗi: {(int)response.StatusCode}";
                    }
                    catch { errorMessage = $"GitHub PR lỗi: {(int)response.StatusCode}"; }
                }
            }
            else if (inputMode == "files")
            {
                // Read file content client-side for Diff
                var sb = new System.Text.StringBuilder();
                using var form = new MultipartFormDataContent();
                form.Add(new StringContent(selectedPersona), "persona");
                if (customRules.Count > 0)
                    form.Add(new StringContent(string.Join("\n", customRules)), "customRules");
                foreach (var file in uploadedFiles)
                {
                    var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    var content = System.Text.Encoding.UTF8.GetString(ms.ToArray());
                    sb.AppendLine($"// === FILE: {file.Name} ===");
                    sb.AppendLine(content);
                    ms.Position = 0;
                    form.Add(new StreamContent(ms), "files", file.Name);
                }
                reviewedCode = sb.ToString();
                var response = await http.PostAsync("api/review/files", form);
                if (response.IsSuccessStatusCode)
                    dto = await response.Content.ReadFromJsonAsync<ReviewResponseDto>();
                else
                    errorMessage = $"Upload lỗi: {(int)response.StatusCode}";
            }
            else
            {
                reviewedCode = codeContent ?? "";
                var request = new ReviewRequestDto
                {
                    Code = codeContent,
                    Persona = selectedPersona,
                    CustomRules = customRules.Count > 0 ? customRules : null
                };
                var response = await http.PostAsJsonAsync("api/review", request);
                if (response.IsSuccessStatusCode)
                    dto = await response.Content.ReadFromJsonAsync<ReviewResponseDto>();
                else
                    errorMessage = $"API trả về lỗi: {(int)response.StatusCode} {response.StatusCode}";
            }

            if (dto != null && !string.IsNullOrEmpty(dto.ErrorMessage))
                errorMessage = dto.ErrorMessage;
            else if (dto != null)
            {
                responseDto = dto;
                await SaveToHistory(dto, reviewedCode);

                // Flowchart is generated in a separate non-blocking call so the review
                // result appears immediately without waiting for the AI chart generation.
                bool needsFlowchart = reviewedInputMode != "github"
                    && !(reviewedInputMode == "files" && uploadedFiles.Count > 1);
                if (needsFlowchart)
                    _ = LoadFlowchartAsync(reviewedCode);
            }
        }
        catch (Exception ex) { errorMessage = $"Không thể kết nối API: {ex.Message}"; }
        finally { isLoading = false; }
    }

    // Lazy flowchart loading — called after review result is shown
    bool isLoadingFlowchart = false;

    async Task LoadFlowchartAsync(string codeForChart)
    {
        try
        {
            isLoadingFlowchart = true;
            await InvokeAsync(StateHasChanged);

            var http = HttpClientFactory.CreateClient("ReviewApi");
            var resp = await http.PostAsJsonAsync("api/review/flowchart",
                new { Code = codeForChart.Length > 40_000 ? codeForChart[..40_000] : codeForChart });
            if (resp.IsSuccessStatusCode && responseDto != null)
            {
                var result = await resp.Content.ReadFromJsonAsync<FlowchartResult>();
                if (result != null)
                    responseDto.MermaidChart = result.MermaidChart;
            }
        }
        catch { }
        finally
        {
            isLoadingFlowchart = false;
            try { await InvokeAsync(StateHasChanged); } catch { }
        }
    }

    record FlowchartResult(string MermaidChart);

