    // Strip "// === FILE: name ===" header added by the upload handler so it doesn't
    // appear as a deleted line in the Diff view.
    string StripFileHeader(string code)
    {
        var t = code.TrimStart();
        if (t.StartsWith("// === FILE:"))
        {
            var nl = code.IndexOf('\n');
            return nl >= 0 ? code[(nl + 1)..] : code;
        }
        return code;
    }

    // Diff
    record DiffLine(string Type, string Content);

    static List<DiffLine> ComputeDiff(string original, string fixedCode)
    {
        // Normalize line endings before splitting
        var origLines  = (original  ?? "").Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');
        var fixedLines = (fixedCode ?? "").Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');
        int m = origLines.Length, n = fixedLines.Length;

        // Compare trimmed lines so trailing-whitespace-only differences don't show as changes
        static string Key(string s) => s.TrimEnd();

        var dp = new int[m + 1, n + 1];
        for (int i = 1; i <= m; i++)
            for (int j = 1; j <= n; j++)
                dp[i, j] = Key(origLines[i - 1]) == Key(fixedLines[j - 1])
                    ? dp[i - 1, j - 1] + 1
                    : Math.Max(dp[i - 1, j], dp[i, j - 1]);

        var diff = new List<DiffLine>();
        int x = m, y = n;
        while (x > 0 || y > 0)
        {
            if (x > 0 && y > 0 && Key(origLines[x - 1]) == Key(fixedLines[y - 1]))
            { diff.Add(new DiffLine("equal", origLines[x - 1])); x--; y--; }
            else if (y > 0 && (x == 0 || dp[x, y - 1] >= dp[x - 1, y]))
            { diff.Add(new DiffLine("insert", fixedLines[y - 1])); y--; }
            else
            { diff.Add(new DiffLine("delete", origLines[x - 1])); x--; }
        }
        diff.Reverse();
        return diff;
    }

