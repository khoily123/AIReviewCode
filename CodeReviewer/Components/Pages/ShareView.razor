@page "/share/{Id}"
@using AIReviewerAPI.DTOs
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

<div style="min-height:100vh;background:#f1f5f9;font-family:'Outfit',sans-serif;">
    <div style="max-width:1000px;margin:0 auto;padding:2rem 1rem;">

        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" style="width:3rem;height:3rem;"></div>
                <p class="mt-3 text-muted fw-semibold">Đang tải báo cáo...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="text-center py-5">
                <div style="font-size:4rem;">🔗</div>
                <h4 class="fw-bold text-danger mt-3">@errorMsg</h4>
                <p class="text-muted">Link chia sẻ chỉ có hiệu lực trong 24 giờ.</p>
                <a href="/" class="btn btn-primary mt-2" style="border-radius:10px;">
                    <i class="bi bi-rocket-takeoff me-1"></i> Review code của bạn
                </a>
            </div>
        }
        else if (reviewData != null)
        {
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <div style="font-size:0.8rem;background:rgba(99,102,241,0.1);color:#4f46e5;border:1px solid rgba(99,102,241,0.2);border-radius:20px;padding:0.3rem 0.8rem;display:inline-block;margin-bottom:0.5rem;">
                        <i class="bi bi-share-fill me-1"></i> Shared Code Review
                    </div>
                    <h4 class="fw-bold mb-0" style="color:#0f172a;">Kết quả phân tích code</h4>
                    <small class="text-muted">Chia sẻ lúc @createdAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <a href="/" class="btn btn-primary" style="border-radius:10px;">
                    <i class="bi bi-rocket-takeoff me-1"></i> Review code của bạn
                </a>
            </div>

            <!-- Score cards -->
            <div class="row g-3 mb-4">
                <div class="col-4">
                    <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                        <i class="bi bi-lightning-charge-fill text-warning mb-1"></i>
                        <div class="fw-bold fs-3 text-warning">@reviewData.PerformanceScore</div>
                        <small class="text-muted">Hiệu suất</small>
                        <div class="progress mt-2" style="height:6px;border-radius:10px;">
                            <div class="progress-bar bg-warning" style="width:@(reviewData.PerformanceScore)%;transition:width 1.5s;"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                        <i class="bi bi-shield-lock-fill text-danger mb-1"></i>
                        <div class="fw-bold fs-3 text-danger">@reviewData.SecurityScore</div>
                        <small class="text-muted">Bảo mật</small>
                        <div class="progress mt-2" style="height:6px;border-radius:10px;">
                            <div class="progress-bar bg-danger" style="width:@(reviewData.SecurityScore)%;transition:width 1.5s;"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 shadow-sm text-center p-3" style="border-radius:14px;">
                        <i class="bi bi-code-square text-success mb-1"></i>
                        <div class="fw-bold fs-3 text-success">@reviewData.MaintainabilityScore</div>
                        <small class="text-muted">Bảo trì</small>
                        <div class="progress mt-2" style="height:6px;border-radius:10px;">
                            <div class="progress-bar bg-success" style="width:@(reviewData.MaintainabilityScore)%;transition:width 1.5s;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="card border-0 shadow-sm" style="border-radius:16px;overflow:hidden;">
                <div style="background:#0f172a;display:flex;gap:4px;padding:0.75rem 1rem 0;">
                    @foreach (var tab in new[] { ("analysis","bi-bug","Phân tích"), ("original","bi-code-slash","Code gốc"), ("fixed","bi-magic","Auto Fix"), ("tests","bi-clipboard2-pulse","Unit Tests") })
                    {
                        <button @onclick="() => activeTab = tab.Item1"
                                style="background:@(activeTab == tab.Item1 ? "white" : "transparent");color:@(activeTab == tab.Item1 ? "#4f46e5" : "#94a3b8");border:none;padding:0.6rem 1rem;border-radius:8px 8px 0 0;font-weight:600;font-size:0.85rem;cursor:pointer;transition:all 0.2s;">
                            <i class="bi @tab.Item2 me-1"></i> @tab.Item3
                        </button>
                    }
                </div>

                <div style="background:white;padding:1.5rem;min-height:300px;">
                    @if (activeTab == "analysis")
                    {
                        <!-- Summary -->
                        <div style="background:linear-gradient(to right,#f0fdf4,#fff);border:1px solid #bbf7d0;border-left:5px solid #10b981;padding:1rem 1.2rem;border-radius:10px;margin-bottom:1.5rem;">
                            <strong style="color:#059669;"><i class="bi bi-card-text me-1"></i> Tổng quan</strong>
                            <p style="margin:0.5rem 0 0;color:#334155;line-height:1.6;">@reviewData.Summary</p>
                        </div>

                        @if (reviewData.DetectedBugs?.Any() == true)
                        {
                            <div class="fw-bold text-muted mb-3">
                                <i class="bi bi-bug me-1 text-danger"></i> Lỗi phát hiện (@reviewData.DetectedBugs.Count)
                            </div>
                            @foreach (var bug in reviewData.DetectedBugs)
                            {
                                <div style="background:#fff;border:1px solid #fed7aa;border-left:4px solid #f97316;padding:0.9rem 1.1rem;border-radius:8px;margin-bottom:0.75rem;display:flex;gap:0.75rem;align-items:flex-start;">
                                    <span style="background:#f97316;color:white;padding:3px 10px;border-radius:6px;font-size:0.82rem;font-weight:700;white-space:nowrap;">Line @bug.Line</span>
                                    <span style="color:#451a03;line-height:1.5;">@bug.Description</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <span style="font-size:3rem;">🎉</span>
                                <p class="fw-bold text-success mt-2">Không phát hiện lỗi nào!</p>
                            </div>
                        }
                    }
                    else if (activeTab == "original")
                    {
                        @if (string.IsNullOrEmpty(originalCode))
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-code-slash fs-1 opacity-25"></i>
                                <p class="mt-2">Không có code gốc được lưu.</p>
                            </div>
                        }
                        else
                        {
                            <div style="background:#2d2d2d;border-radius:10px;overflow:auto;max-height:500px;padding:1.5rem;">
                                <pre style="margin:0;"><code class="language-csharp">@originalCode</code></pre>
                            </div>
                        }
                    }
                    else if (activeTab == "fixed")
                    {
                        @if (string.IsNullOrEmpty(reviewData.FixedCode))
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-magic fs-1 opacity-25"></i>
                                <p class="mt-2 fw-semibold">Không có code đã sửa.</p>
                                <p class="small">AI không thể tạo bản sửa cho đoạn code này.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-end mb-2">
                                <button class="btn btn-sm btn-primary" style="border-radius:8px;" @onclick="CopyFixed">
                                    <i class="bi @(fixedCopied ? "bi-check2-all" : "bi-clipboard") me-1"></i>
                                    @(fixedCopied ? "Đã Copy!" : "Copy")
                                </button>
                            </div>
                            <div style="background:#2d2d2d;border-radius:10px;overflow:auto;max-height:500px;padding:1.5rem;">
                                <pre style="margin:0;"><code class="language-csharp">@reviewData.FixedCode</code></pre>
                            </div>
                        }
                    }
                    else if (activeTab == "tests")
                    {
                        @if (string.IsNullOrEmpty(reviewData.UnitTests))
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-clipboard2-x fs-1 opacity-25"></i>
                                <p class="mt-2">Không có unit tests được tạo.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-end mb-2">
                                <button class="btn btn-sm btn-primary" style="border-radius:8px;" @onclick="CopyTests">
                                    <i class="bi @(testsCopied ? "bi-check2-all" : "bi-clipboard") me-1"></i>
                                    @(testsCopied ? "Đã Copy!" : "Copy")
                                </button>
                            </div>
                            <div style="background:#2d2d2d;border-radius:10px;overflow:auto;max-height:500px;padding:1.5rem;">
                                <pre style="margin:0;"><code class="language-csharp">@reviewData.UnitTests</code></pre>
                            </div>
                        }
                    }
                </div>
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    bool isLoading = true;
    string? errorMsg;
    ReviewResponseDto? reviewData;
    string originalCode = "";
    DateTime createdAt;
    string activeTab = "analysis";
    bool fixedCopied = false;
    bool testsCopied = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("ReviewApi");
            var resp = await http.GetAsync($"api/share/{Id}");
            if (!resp.IsSuccessStatusCode)
            {
                errorMsg = "Link đã hết hạn hoặc không tồn tại.";
                return;
            }
            var data = await resp.Content.ReadFromJsonAsync<SharedReviewResult>();
            reviewData = data?.ReviewData;
            originalCode = data?.OriginalCode ?? "";
            createdAt = data?.CreatedAt ?? DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            errorMsg = $"Không thể tải báo cáo: {ex.Message}";
        }
        finally { isLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && reviewData != null && (activeTab == "original" || activeTab == "fixed" || activeTab == "tests"))
            try { await JS.InvokeVoidAsync("highlightCode"); } catch { }
    }

    async Task CopyFixed()
    {
        if (string.IsNullOrEmpty(reviewData?.FixedCode)) return;
        await JS.InvokeVoidAsync("clipboardCopy.copyText", reviewData.FixedCode);
        fixedCopied = true; StateHasChanged();
        await Task.Delay(2000);
        fixedCopied = false; StateHasChanged();
    }

    async Task CopyTests()
    {
        if (string.IsNullOrEmpty(reviewData?.UnitTests)) return;
        await JS.InvokeVoidAsync("clipboardCopy.copyText", reviewData.UnitTests);
        testsCopied = true; StateHasChanged();
        await Task.Delay(2000);
        testsCopied = false; StateHasChanged();
    }

    record SharedReviewResult(ReviewResponseDto ReviewData, string OriginalCode, DateTime CreatedAt);
}
